FROM php:8.4-apache

RUN apt-get update && apt-get install -y --no-install-recommends \
    libzip-dev libicu-dev libpng-dev libonig-dev \
    && docker-php-ext-install pdo_mysql zip intl bcmath gd \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/dashboards

COPY composer.json composer.lock ./
RUN composer install --no-scripts

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

RUN chown -R www-data:www-data storage bootstrap/cache database \
    && chmod -R 775 storage bootstrap/cache database

RUN composer dump-autoload
RUN npm run build

RUN sed -ri -e 's!/var/www/html!/var/www/dashboards/public!g' /etc/apache2/sites-available/*.conf \
    && sed -ri -e 's!AllowOverride None!AllowOverride All!g' /etc/apache2/sites-available/*.conf \
    && a2enmod rewrite

EXPOSE 80